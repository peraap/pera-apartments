# Email Configuration (Nodemailer/Gmail)
GMAIL_USER=contact.peraapartments@gmail.com
GMAIL_APP_PASSWORD=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Sheets & Calendar Integration (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# Consolidated Calendar IDs (Saves space/slots):
# You need one Google Calendar ID for EACH room for full sync.
# Create 6 calendars in Google Calendar and put their IDs here.
# Example: {"apartament-premium-king": "id1", "apartament-deluxe-double": "id2", "apartament-family-standard": "id3", "apartament-family-deluxe": "id4", "peraduo": "id5", "peraconfort": "id6"}
GOOGLE_CALENDAR_IDS_JSON=

# Toggle site maintenance mode
MAINTENANCE_MODE=true

# ICal Sync URLs (Direct connection from Booking/Airbnb for faster updates)
ICAL_BOOKING_PREMIUM_KING=
ICAL_BOOKING_DELUXE_DOUBLE=
ICAL_BOOKING_FAMILY_STANDARD=
ICAL_BOOKING_FAMILY_DELUXE=
ICAL_BOOKING_PERADUO=
ICAL_BOOKING_PERACONFORT=

# Airbnb is only for PeraDuo and PeraConfort
ICAL_AIRBNB_PERADUO=
ICAL_AIRBNB_PERACONFORT=
